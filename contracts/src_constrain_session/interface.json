{
  "component_id": "src_constrain_session",
  "name": "Session Lifecycle and Persistence Manager",
  "description": "Manages session creation, persistence, and retrieval for the constrain system. Provides lifecycle management including phase transitions, file-based persistence in JSON format, and session discovery utilities.",
  "version": 1,
  "types": [
    {
      "name": "SessionManager",
      "kind": "struct",
      "fields": [
        {
          "name": "base_path",
          "type_ref": "Path",
          "required": true,
          "default": "",
          "description": "Base directory path for session storage",
          "validators": []
        },
        {
          "name": "_sessions_dir",
          "type_ref": "Path",
          "required": true,
          "default": "",
          "description": "Directory path where session JSON files are stored (.constrain/sessions)",
          "validators": []
        }
      ],
      "item_type": "",
      "variants": [],
      "inner_types": [],
      "description": "Class that manages session creation, persistence, and retrieval operations"
    },
