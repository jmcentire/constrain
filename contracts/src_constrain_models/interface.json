  "functions": [
    {
      "name": "apply_update",
      "description": "Mutates ProblemModel instance by applying updates from a dictionary. String fields are replaced; list fields are appended to (strings only if not already present, dicts always appended). Ignores keys not in model_fields.",
      "inputs": [
        {
          "name": "self",
          "type_ref": "ProblemModel",
          "required": true,
          "default": "",
          "description": "The ProblemModel instance to update",
          "validators": []
        },
        {
          "name": "update",
          "type_ref": "dict",
          "required": true,
          "default": "",
          "description": "Dictionary containing field updates to apply",
          "validators": []
        }
      ],
      "output_type": "None",
      "error_cases": [
        {
          "name": "AttributeError",
          "condition": "If getattr fails (should not occur under normal operation with valid Pydantic model)",
          "error_type": "AttributeError",
          "error_data": {}
        }
      ],
      "preconditions": [
        "update must be a dict"
      ],
      "postconditions": [
        "For each key in update that exists in self.model_fields: if current field is str, it is replaced with update[key]; if current field is list, update[key] items are appended (strings only if not duplicate, dicts always)",
        "Fields not in self.model_fields are ignored",
        "self is mutated in place"
      ],
      "idempotent": false,
      "side_effects": [
        "Mutates the ProblemModel instance fields"
      ],
      "structured_side_effects": [
        {
          "kind": "mutates_state",
          "target": "self",
          "description": "Updates string and list fields based on update dict"
        }
      ],
      "performance_budget": null
    },
    {
      "name": "touch",
      "description": "Updates the updated_at timestamp of a Session instance to the current UTC time in ISO format.",
      "inputs": [
        {
          "name": "self",
          "type_ref": "Session",
          "required": true,
          "default": "",
          "description": "The Session instance to update",
          "validators": []
        }
      ],
      "output_type": "None",
      "error_cases": [],
      "preconditions": [],
      "postconditions": [
        "self.updated_at is set to current UTC timestamp in ISO format",
        "self is mutated in place"
      ],
      "idempotent": false,
      "side_effects": [
        "Mutates the Session instance updated_at field"
      ],
      "structured_side_effects": [
        {
          "kind": "mutates_state",
          "target": "self.updated_at",
          "description": "Sets updated_at to current UTC timestamp"
        }
      ],
      "performance_budget": null
    }
  ],
